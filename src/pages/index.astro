---
import { Grid } from "../components/grid";
import { Products } from "../components/products";
import Layout from "../layouts/Layout.astro";
import { fetchFrontPage } from "../use-cases/queries/frontpage.ts";
import { hardcodedProductCards } from "../use-cases/data/product-cards";

const data = await fetchFrontPage("/frontpage", "published");
const { catalogue } = data;
const { grid } = catalogue;
---

<Layout
  title="Dounot"
  description="Dounut is a minimal boilerplate built using AstroJS that helps you get started with Crystallize.">
  <div class="py-10 mx-auto w-full max-w-[1040px] md:px-0 px-3">
    <Grid grid={grid} />
    <Products donuts={hardcodedProductCards} />
  </div>
</Layout>
