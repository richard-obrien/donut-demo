---
import { BasketButton } from "./basket-button";
import AstroLogo from "../assets/astro-logo.svg";
---

<header class="lg:container flex justify-between mx-auto py-10 w-full md:px-0 px-3">
  <a href="/" title="AstroJS">
    <img src={AstroLogo.src} alt="Dount and Astro logo" class="w-24" />
  </a>
  <a href="/cart" title="Your cart">
    <BasketButton client:load />
  </a>
</header>
